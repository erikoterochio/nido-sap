// Benveo CoLiving - Schema de Base de Datos

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTENTICACIÓN Y USUARIOS
// ============================================================================

model Usuario {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  nombre        String
  rol           Rol
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  empleado      Empleado?
  auditLogs     AuditLog[]

  @@map("usuario")
}

enum Rol {
  ADMIN
  STAFF
}

// ============================================================================
// EMPLEADOS
// ============================================================================

model Empleado {
  id                String    @id @default(cuid())
  usuarioId         String?   @unique
  nombre            String
  apellido          String
  dni               String?
  telefono          String?
  email             String?
  precioHoraNormal  Decimal   @db.Decimal(10, 2) @default(6000)
  precioHoraFinde   Decimal   @db.Decimal(10, 2) @default(7000)
  cvuAlias          String?
  saldoPendiente    Decimal   @db.Decimal(12, 2) @default(0)
  activo            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  usuario           Usuario?  @relation(fields: [usuarioId], references: [id])
  turnos            TurnoLimpieza[]
  gastos            Gasto[]
  pagos             PagoEmpleado[]
  anticipos         Anticipo[]

  @@map("empleado")
}

// ============================================================================
// DEPARTAMENTOS
// ============================================================================

model Departamento {
  id                    String                @id @default(cuid())
  nombre                String                @unique
  direccion             String?
  duenos                String[]
  mailDueno             String?
  comisionPorcentaje    Decimal               @db.Decimal(5, 4) @default(0.20)
  quienPagaServicios    ResponsableServicios  @default(BENVEO)
  descuentoBajarDinero  Boolean               @default(false)
  limpiezasIncluidas    Boolean               @default(false)
  airbnbId              String?
  estado                EstadoDepartamento    @default(ACTIVO)
  limiteHoras           Decimal               @db.Decimal(4, 2) @default(4)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  turnos                TurnoLimpieza[]
  gastos                Gasto[]
  ingresos              IngresoMensual[]
  liquidaciones         Liquidacion[]

  @@map("departamento")
}

enum EstadoDepartamento {
  ACTIVO
  INACTIVO
  MANTENIMIENTO
}

enum ResponsableServicios {
  DUENO
  BENVEO
}

// ============================================================================
// TURNOS DE LIMPIEZA
// ============================================================================

model TurnoLimpieza {
  id              String        @id @default(cuid())
  departamentoId  String
  empleadoId      String
  fecha           DateTime      @db.Date
  horaEntrada     String
  horaSalida      String
  duracionHoras   Decimal       @db.Decimal(4, 2)
  viaticos        Decimal       @db.Decimal(10, 2) @default(0)
  esFeriadoFinde  Boolean       @default(false)
  comentarios     String?
  tipo            TipoTurno     @default(LIMPIEZA)
  precioHora      Decimal       @db.Decimal(10, 2)
  montoTotal      Decimal       @db.Decimal(12, 2)
  mes             DateTime      @db.Date
  estado          EstadoTurno   @default(PENDIENTE_REVISION)
  alertas         String[]
  pagoId          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  departamento    Departamento  @relation(fields: [departamentoId], references: [id])
  empleado        Empleado      @relation(fields: [empleadoId], references: [id])
  pago            PagoEmpleado? @relation(fields: [pagoId], references: [id])
  historial       HistorialCambio[]

  @@map("turno")
  @@index([departamentoId, mes])
  @@index([empleadoId, mes])
  @@index([estado])
}

enum EstadoTurno {
  PENDIENTE_REVISION
  APROBADO
  PAGADO
}

enum TipoTurno {
  LIMPIEZA
  MANTENIMIENTO
}

// ============================================================================
// GASTOS
// ============================================================================

model TipoGasto {
  id          String          @id @default(cuid())
  nombre      String          @unique
  categoria   CategoriaGasto
  esServicio  Boolean         @default(false)
  activo      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  gastos      Gasto[]

  @@map("tipogasto")
}

enum CategoriaGasto {
  SERVICIOS
  LIMPIEZA_LAVANDERIA
  REEMPLAZO_REPOSICION
  MANTENIMIENTO
  TRASLADOS
  INSUMOS_LIMPIEZA
  OTROS
}

model Gasto {
  id              String      @id @default(cuid())
  departamentoId  String
  empleadoId      String
  tipoGastoId     String
  fecha           DateTime    @db.Date
  monto           Decimal     @db.Decimal(12, 2)
  quienPago       QuienPago
  comentarios     String?
  mes             DateTime    @db.Date
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  departamento    Departamento  @relation(fields: [departamentoId], references: [id])
  empleado        Empleado      @relation(fields: [empleadoId], references: [id])
  tipoGasto       TipoGasto     @relation(fields: [tipoGastoId], references: [id])
  historial       HistorialCambio[]

  @@map("gasto")
  @@index([departamentoId, mes])
}

enum QuienPago {
  TARJETA_BENVEO
  EFECTIVO_EMPLEADO
  TRANSFERENCIA
}

// ============================================================================
// INGRESOS Y LIQUIDACIONES
// ============================================================================

model IngresoMensual {
  id              String        @id @default(cuid())
  departamentoId  String
  mes             DateTime      @db.Date
  ingresoBrutoUSD Decimal       @db.Decimal(14, 2)
  fuente          String?
  notas           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  departamento    Departamento  @relation(fields: [departamentoId], references: [id])

  @@map("ingresomensual")
  @@unique([departamentoId, mes])
}

model Liquidacion {
  id                    String              @id @default(cuid())
  departamentoId        String
  mes                   DateTime            @db.Date
  ingresoBrutoUSD       Decimal             @db.Decimal(14, 2)
  comisionPorcentaje    Decimal             @db.Decimal(5, 4)
  comisionMonto         Decimal             @db.Decimal(14, 2)
  ingresoNetoUSD        Decimal             @db.Decimal(14, 2)
  gastosServicios       Decimal             @db.Decimal(14, 2) @default(0)
  detalleServicios      Json?
  gastosLimpiezaTurnos  Decimal             @db.Decimal(14, 2) @default(0)
  gastosLimpiezaInsumos Decimal             @db.Decimal(14, 2) @default(0)
  gastosLimpiezaOtros   Decimal             @db.Decimal(14, 2) @default(0)
  totalHorasLimpieza    Decimal             @db.Decimal(6, 2) @default(0)
  gastosMantenimiento   Decimal             @db.Decimal(14, 2) @default(0)
  gastosReposicion      Decimal             @db.Decimal(14, 2) @default(0)
  gastosOtros           Decimal             @db.Decimal(14, 2) @default(0)
  totalGastosARS        Decimal             @db.Decimal(14, 2)
  tipoCambio            Decimal             @db.Decimal(10, 2)
  totalGastosUSD        Decimal             @db.Decimal(14, 2)
  saldoLiquidacionUSD   Decimal             @db.Decimal(14, 2)
  saldoLiquidacionARS   Decimal             @db.Decimal(14, 2)
  estado                EstadoLiquidacion   @default(BORRADOR)
  fechaAprobacion       DateTime?
  fechaEnvio            DateTime?
  fechaPago             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  departamento          Departamento        @relation(fields: [departamentoId], references: [id])

  @@map("liquidacion")
  @@unique([departamentoId, mes])
}

enum EstadoLiquidacion {
  BORRADOR
  LISTO_PARA_REVISAR
  APROBADO
  ENVIADO
  PAGADO
}

// ============================================================================
// PAGOS Y ANTICIPOS
// ============================================================================

model PagoEmpleado {
  id            String      @id @default(cuid())
  empleadoId    String
  fecha         DateTime    @db.Date
  monto         Decimal     @db.Decimal(12, 2)
  concepto      String
  periodo       String?
  metodoPago    String?
  comprobante   String?
  notas         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  empleado      Empleado    @relation(fields: [empleadoId], references: [id])
  turnos        TurnoLimpieza[]

  @@map("pagoempleado")
}

model Anticipo {
  id            String          @id @default(cuid())
  empleadoId    String
  fecha         DateTime        @db.Date
  monto         Decimal         @db.Decimal(12, 2)
  motivo        String?
  estado        EstadoAnticipo  @default(PENDIENTE)
  descontadoEn  DateTime?       @db.Date
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  empleado      Empleado        @relation(fields: [empleadoId], references: [id])

  @@map("anticipo")
}

enum EstadoAnticipo {
  PENDIENTE
  DESCONTADO
}

// ============================================================================
// CONFIGURACIÓN Y CALENDARIO
// ============================================================================

model Configuracion {
  id          String    @id @default(cuid())
  clave       String    @unique
  valor       Json
  descripcion String?
  updatedAt   DateTime  @updatedAt

  @@map("configuracion")
}

model DiaEspecial {
  id          String          @id @default(cuid())
  fecha       DateTime        @db.Date @unique
  tipo        TipoDiaEspecial
  descripcion String?
  createdAt   DateTime        @default(now())

  @@map("diaespecial")
}

enum TipoDiaEspecial {
  FERIADO
  DIA_NO_LABORABLE
}

// ============================================================================
// AUDITORÍA
// ============================================================================

model HistorialCambio {
  id              String    @id @default(cuid())
  entidad         String
  entidadId       String
  campoModificado String
  valorAnterior   String?
  valorNuevo      String?
  motivo          String
  comentario      String?
  usuarioId       String
  createdAt       DateTime  @default(now())

  turno           TurnoLimpieza?  @relation(fields: [entidadId], references: [id], map: "historial_turno")
  gasto           Gasto?          @relation(fields: [entidadId], references: [id], map: "historial_gasto")

  @@map("historialcambio")
  @@index([entidad, entidadId])
}

model AuditLog {
  id          String    @id @default(cuid())
  usuarioId   String
  accion      String
  entidad     String?
  entidadId   String?
  detalles    Json?
  ip          String?
  createdAt   DateTime  @default(now())

  usuario     Usuario   @relation(fields: [usuarioId], references: [id])

  @@map("auditlog")
  @@index([usuarioId])
  @@index([entidad, entidadId])
}
